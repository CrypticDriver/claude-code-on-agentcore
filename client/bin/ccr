#!/usr/bin/env python3
"""
ccr — Claude Code Remote. Thin client for a Claude Code AgentCore runtime.

The agent runs entirely inside Amazon Bedrock AgentCore; this client only
sends prompts (SigV4) and renders the event stream. Nothing is executed or
collected locally.

Usage:
  ccr                                              # interactive session
  ccr "Explain what an EC2 instance is in one sentence."
  ccr "My name is Ada."; ccr "What's my name?"     # multi-turn, resumed
  ccr --new-session

Runtime ARN resolution order:
  --runtime <arn>  >  $CC_AGENTCORE_RUNTIME_ARN  >  ~/.ccr/runtime.arn
The session id persists in ~/.ccr/session.id so consecutive shell commands
continue the same conversation.
"""
from __future__ import annotations

import argparse
import json
import os
import sys
import threading
import time
import uuid
from pathlib import Path

import boto3

STATE_DIR = Path.home() / ".ccr"
SESSION_FILE = STATE_DIR / "session.id"
RUNTIME_FILE = STATE_DIR / "runtime.arn"

TTY = sys.stdout.isatty() and not os.environ.get("NO_COLOR")
if TTY:
    DIM, BOLD, CYAN, YELLOW, RED, RESET = (
        "\033[90m", "\033[1m", "\033[36m", "\033[33m", "\033[31m", "\033[0m")
else:
    DIM = BOLD = CYAN = YELLOW = RED = RESET = ""


class Spinner:
    """Animated 'still working' line between stream events (TTY only)."""

    FRAMES = "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"

    def __init__(self) -> None:
        self._lock = threading.Lock()
        self._msg = ""
        self._started = 0.0
        self._stop = threading.Event()
        self._thread: threading.Thread | None = None

    def start(self, msg: str) -> None:
        if not TTY:
            return
        self._msg, self._started = msg, time.time()
        self._stop.clear()
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()

    def set(self, msg: str) -> None:
        with self._lock:
            self._msg, self._started = msg, time.time()

    def _run(self) -> None:
        i = 0
        while not self._stop.wait(0.1):
            with self._lock:
                frame = self.FRAMES[i % len(self.FRAMES)]
                elapsed = int(time.time() - self._started)
                sys.stdout.write(f"\r\033[2K{DIM}{frame} {self._msg} ({elapsed}s){RESET}")
                sys.stdout.flush()
            i += 1

    def println(self, text: str, file=sys.stdout) -> None:
        """Print a line without racing the animation thread."""
        with self._lock:
            if TTY and self._thread is not None:
                sys.stdout.write("\r\033[2K")
                sys.stdout.flush()
            print(text, file=file)

    def stop(self) -> None:
        if self._thread is None:
            return
        self._stop.set()
        self._thread.join()
        sys.stdout.write("\r\033[2K")
        sys.stdout.flush()
        self._thread = None


def resolve_runtime_arn(cli_arg: str | None) -> str:
    for candidate in (cli_arg, os.environ.get("CC_AGENTCORE_RUNTIME_ARN")):
        if candidate and candidate.strip():
            return candidate.strip()
    if RUNTIME_FILE.exists():
        contents = RUNTIME_FILE.read_text().strip()
        if contents:
            return contents
    sys.exit(
        "error: runtime ARN not set. Pass --runtime <arn>, set "
        f"CC_AGENTCORE_RUNTIME_ARN, or write it to {RUNTIME_FILE}."
    )


def resolve_session_id(new_session: bool) -> str:
    if not new_session and SESSION_FILE.exists():
        existing = SESSION_FILE.read_text().strip()
        if existing:
            return existing
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    fresh = f"ccr-{uuid.uuid4()}"
    SESSION_FILE.write_text(fresh + "\n")
    return fresh


def region_from_arn(arn: str) -> str:
    # arn:aws:bedrock-agentcore:REGION:account:runtime/... — using a client in
    # the wrong region fails with a misleading "No endpoint or agent found
    # with qualifier 'DEFAULT'" error.
    parts = arn.split(":")
    return parts[3] if len(parts) > 3 and parts[3] else "us-east-1"


def iter_sse_events(stream):
    """Parse the SSE byte stream into (event, data) pairs."""
    event, data_lines = None, []
    for raw in stream.iter_lines():
        line = raw.decode("utf-8") if isinstance(raw, bytes) else raw
        if line == "":
            if event is not None or data_lines:
                data = "\n".join(data_lines)
                try:
                    data = json.loads(data)
                except (json.JSONDecodeError, ValueError):
                    pass
                yield (event or "message", data)
                event, data_lines = None, []
            continue
        if line.startswith(":"):
            continue
        if line.startswith("event:"):
            event = line[6:].strip()
        elif line.startswith("data:"):
            data_lines.append(line[5:].removeprefix(" "))
    if event is not None or data_lines:
        data = "\n".join(data_lines)
        try:
            data = json.loads(data)
        except (json.JSONDecodeError, ValueError):
            pass
        yield (event or "message", data)


def render_cc(obj: dict, rel: str, spin: Spinner) -> None:
    kind = obj.get("type")
    if kind == "system" and obj.get("subtype") == "init":
        spin.println(f"{DIM}[{rel}s] init         model={obj.get('model', '?')}{RESET}")
        spin.set("Claude Code is thinking")
    elif kind == "assistant":
        for block in (obj.get("message") or {}).get("content") or []:
            if block.get("type") == "text" and block.get("text", "").strip():
                spin.println(f"[{rel}s] {block['text'].strip()}")
            elif block.get("type") == "tool_use":
                spin.println(f"{YELLOW}[{rel}s] tool_use     {block.get('name')}{RESET}")
                spin.set(f"running {block.get('name')}")
    elif kind == "user":
        for block in (obj.get("message") or {}).get("content") or []:
            if isinstance(block, dict) and block.get("type") == "tool_result":
                content = block.get("content")
                text = content if isinstance(content, str) else json.dumps(content)
                spin.println(f"{DIM}[{rel}s] tool_result  {text[:160].replace(chr(10), ' ')}{RESET}")
                spin.set("Claude Code is thinking")
    elif kind == "result":
        spin.println(
            f"{DIM}[{rel}s] result       turns={obj.get('num_turns')} "
            f"cost=${obj.get('total_cost_usd')}{RESET}"
        )


def send(client, runtime_arn: str, session_id: str, prompt: str,
         echo_prompt: bool = True) -> int:
    if echo_prompt:
        print(f"\n{BOLD}{CYAN}> {prompt}{RESET}")
    started = time.time()
    exit_code = 0

    spin = Spinner()
    spin.start("connecting to the runtime")
    try:
        resp = client.invoke_agent_runtime(
            agentRuntimeArn=runtime_arn,
            runtimeSessionId=session_id,
            contentType="application/json",
            accept="text/event-stream",
            payload=json.dumps({"prompt": prompt}).encode(),
        )
        spin.set("starting Claude Code in the sandbox")

        for event, data in iter_sse_events(resp["response"]):
            rel = f"{time.time() - started:.2f}"
            if event == "start" and isinstance(data, dict):
                resumed = data.get("resumed_cc_session_id")
                if resumed:
                    spin.println(f"{DIM}[{rel}s] start        resumed {resumed[:8]}{RESET}")
                else:
                    spin.println(f"{DIM}[{rel}s] start        fresh session "
                                 f"(first turn initializes the sandbox — expect ~30s; "
                                 f"later turns are faster){RESET}")
                spin.set("starting Claude Code in the sandbox")
            elif event == "cc" and isinstance(data, dict):
                render_cc(data, rel, spin)
            elif event == "error":
                spin.println(f"{RED}[{rel}s] error        {json.dumps(data)}{RESET}",
                             file=sys.stderr)
                exit_code = 1
            elif event == "done" and isinstance(data, dict):
                if data.get("exit_code") not in (0, None):
                    exit_code = 1
                spin.println(f"{DIM}— done in {time.time() - started:.2f}s —{RESET}")
    finally:
        spin.stop()
    return exit_code


def repl(client, runtime_arn: str, session_id: str) -> None:
    try:
        import readline  # noqa: F401  (arrow-key history in input())
    except ImportError:
        pass
    print(f"{DIM}Interactive session — type a prompt, blank line or Ctrl-D to exit.{RESET}")
    while True:
        try:
            prompt = input(f"\n{BOLD}{CYAN}> {RESET}").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break
        if not prompt:
            break
        try:
            send(client, runtime_arn, session_id, prompt, echo_prompt=False)
        except KeyboardInterrupt:
            print(f"\n{DIM}(interrupted){RESET}")
        except Exception as e:  # keep the REPL alive on transient errors
            print(f"{RED}error: {e}{RESET}", file=sys.stderr)


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="ccr", description="Claude Code Remote — AgentCore client"
    )
    parser.add_argument("prompts", nargs="*",
                        help="one-off prompts; empty = interactive session")
    parser.add_argument("--runtime", help="AgentCore runtime ARN")
    parser.add_argument("--region", help="AWS region (default: parsed from ARN)")
    parser.add_argument(
        "--new-session", action="store_true", help="start a fresh conversation"
    )
    args = parser.parse_args()

    runtime_arn = resolve_runtime_arn(args.runtime)
    session_id = resolve_session_id(args.new_session)
    region = args.region or region_from_arn(runtime_arn)
    client = boto3.client("bedrock-agentcore", region_name=region)

    print(f"{DIM}runtime: {runtime_arn}{RESET}")
    print(f"{DIM}session: {session_id}{RESET}")

    if args.prompts:
        exit_code = 0
        for prompt in args.prompts:
            exit_code |= send(client, runtime_arn, session_id, prompt)
        if TTY:
            print(f"{DIM}tip: run plain `ccr` for an interactive session{RESET}")
        sys.exit(exit_code)

    repl(client, runtime_arn, session_id)


if __name__ == "__main__":
    main()
